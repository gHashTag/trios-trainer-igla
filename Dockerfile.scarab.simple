# Scarab Worker — minimal image with pre-built binary
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates libssl3 && rm -rf /var/lib/apt/lists/*

# Copy pre-built scarab binary
COPY scarab /usr/local/bin/scarab
RUN chmod +x /usr/local/bin/scarab

ENV RUST_LOG="info"

CMD ["/usr/local/bin/scarab"]
